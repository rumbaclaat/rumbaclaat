// Rumbaclaat — Prisma schema (Prisma 7, new `prisma-client` generator).
// Starter core models; expanded to the full §4 model before the first migration.
// Run `npm run db:push` (or db:migrate) once Supabase DATABASE_URL/DIRECT_URL are set.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Catalogue
// ----------------------------------------------------------------------------

enum ProductType {
  rum
  apparel
  cap
  gift_card
}

enum PublishStatus {
  draft
  published
  archived
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  heroImage   String?
  taxClassId      String?
  shippingClassId String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  sku         String        @unique
  type        ProductType
  name        String
  subtitle    String?
  description String?
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id])
  basePrice   Decimal       @db.Decimal(10, 2)
  onSale      Boolean       @default(false)
  salePrice   Decimal?      @db.Decimal(10, 2)
  saleEndDate DateTime?
  basePoints  Int           @default(0)
  // Rum-specific
  abv          Decimal?     @db.Decimal(5, 2)
  volume       String?
  origin       String?
  tastingNotes String?
  caskType     String?
  ageStatement String?
  // Apparel-specific
  material         String?
  gsm              String?
  fit              String?
  careInstructions String?
  // Display
  ratingAvg   Decimal?      @db.Decimal(3, 2)
  reviewCount Int           @default(0)
  stockQty    Int           @default(0)
  maxQtyPerOrder Int?
  imageUrl    String?
  galleryImages String[]
  // Organisation / merchandising
  taxClassId        String?
  shippingClassId   String?
  lowStockThreshold Int?      @default(5)
  crossSellIds      String[]
  publishAt         DateTime?
  unpublishAt       DateTime?
  // SEO
  seoTitle       String?
  seoDescription String?
  canonical      String?
  status      PublishStatus @default(draft)
  variants    ProductVariant[]
  reviews     Review[]
  collections ProductCollection[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String?
  colourName  String?
  colourHex   String?
  size        String?
  sku         String   @unique
  priceDelta  Decimal  @default(0) @db.Decimal(10, 2)
  stockQty    Int      @default(0)
  imageUrl    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Customers & membership
// ----------------------------------------------------------------------------

model MembershipTier {
  id              String     @id @default(cuid())
  name            String     @unique // Bronze | Silver | Gold | Black Reserve
  slug            String     @unique
  priceMonthly    Decimal    @default(0) @db.Decimal(10, 2)
  priceAnnual     Decimal    @default(0) @db.Decimal(10, 2)
  pointsMultiplier Decimal   @default(1) @db.Decimal(4, 2)
  memberDiscountPct Int      @default(0)
  isFree          Boolean    @default(false)
  benefits        String[]
  sortOrder       Int        @default(0)
  customers       Customer[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Customer {
  id              String          @id @default(cuid())
  authUserId      String?         @unique // Supabase auth.users id
  firstName       String?
  lastName        String?
  email           String          @unique
  phone           String?
  dateOfBirth     DateTime?
  membershipTierId String?
  membershipTier  MembershipTier? @relation(fields: [membershipTierId], references: [id])
  pointsBalance   Int             @default(0)
  lifetimeSpend   Decimal         @default(0) @db.Decimal(12, 2)
  referralCode    String?         @unique
  ghlContactId    String?
  notes           String?
  tags            String[]
  addresses       Address[]
  orders          Order[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String?
  line1      String
  line2      String?
  city       String
  postcode   String
  country    String   @default("United Kingdom")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Site settings (singleton)
// ----------------------------------------------------------------------------

model Settings {
  id                   String  @id @default("default")
  shippingStandardCost Decimal @default(4.99) @db.Decimal(10, 2)
  shippingExpressCost  Decimal @default(9.99) @db.Decimal(10, 2)
  freeShippingThreshold Decimal @default(50) @db.Decimal(10, 2)
  pointsPerPound       Int     @default(100) // 100 points = £1 on redemption
  loyaltyEarnRate      Int     @default(1) // points earned per £ spent
  vatRatePct           Int     @default(20)
  currency             String  @default("GBP")
  baseCurrency         String  @default("GBP")
  ageThreshold         Int     @default(18)
  ageGateEnabled       Boolean @default(true)
  maintenanceMode      Boolean @default(false)
  // Business
  businessName         String?
  businessAddress      String?
  businessVat          String?
  supportEmail         String?
  // SEO defaults
  seoDefaultTitle       String?
  seoDefaultDescription String?
  // Config blobs (filled in admin; live when keys/values set)
  ghlConfig            Json?
  paymentConfig        Json?
  emailConfig          Json?
  branding             Json?
  updatedAt            DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Back-office staff (RBAC) — linked to Supabase auth.users
// ----------------------------------------------------------------------------

enum StaffRole {
  super_admin
  content_editor
  catalogue_manager
  order_manager
  membership_manager
  trade_manager
  marketing_manager
}

model StaffUser {
  id          String    @id @default(cuid())
  authUserId  String    @unique
  email       String    @unique
  name        String?
  role        StaffRole @default(content_editor)
  permissions Json? // string[] of permission keys; null => role defaults
  title       String?
  photo       String?
  active      Boolean   @default(true)
  invitedById String?
  invitedAt   DateTime?
  acceptedAt  DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ----------------------------------------------------------------------------
// Media library (Supabase Storage)
// ----------------------------------------------------------------------------

model Media {
  id         String   @id @default(cuid())
  bucketPath String   @unique
  url        String
  alt        String?
  width      Int?
  height     Int?
  mimeType   String?
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------------
// CMS pages + reorderable content blocks
// ----------------------------------------------------------------------------

enum BlockType {
  hero_carousel
  hero_banner
  announcement_ticker
  trust_bar
  parallax_callout
  featured_products
  sale_strip
  membership_tiers
  membership_promo
  gift_card
  cocktails_grid
  blog_grid
  featured_article
  rich_text
  two_col
  stat_block
  card_grid
  newsletter
  social_grid
  faq_accordion
  cta_band
  reviews
}

model Page {
  id             String         @id @default(cuid())
  slug           String         @unique
  templateType   String         @default("content")
  title          String
  status         PublishStatus  @default(draft)
  seoTitle       String?
  seoDescription String?
  canonical      String?
  robots         String?        @default("index,follow")
  ogImage        String?
  blocks         ContentBlock[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ContentBlock {
  id        String    @id @default(cuid())
  pageId    String
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      BlockType
  order     Int       @default(0)
  visible   Boolean   @default(true)
  data      Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([pageId, order])
}

// ----------------------------------------------------------------------------
// Editorial: blog + cocktails + FAQ
// ----------------------------------------------------------------------------

model Author {
  id     String     @id @default(cuid())
  name   String
  title  String?
  bio    String?
  avatar String?
  posts  BlogPost[]
}

model BlogPost {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  category       String?
  excerpt        String?
  body           String?
  heroImage      String?
  authorId       String?
  author         Author?       @relation(fields: [authorId], references: [id])
  readTime       String?
  featured       Boolean       @default(false)
  status         PublishStatus @default(draft)
  publishDate    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Cocktail {
  id                String        @id @default(cuid())
  slug              String        @unique
  name              String
  eyebrow           String?
  lede              String?
  difficulty        String?
  occasion          String?
  timeMins          Int?
  ingredients       Json?
  method            Json?
  serviceNotes      Json?
  bartenderTip      String?
  image             String?
  featuredProductId String?
  ratingAvg         Decimal?      @db.Decimal(3, 2)
  ratingCount       Int           @default(0)
  tags              String[]
  status            PublishStatus @default(draft)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model FAQItem {
  id        String  @id @default(cuid())
  category  String?
  question  String
  answer    String
  sortOrder Int     @default(0)
}

// ----------------------------------------------------------------------------
// Navigation, banners, promotions, redirects, reviews
// ----------------------------------------------------------------------------

model NavigationMenu {
  id       String    @id @default(cuid())
  location String    @unique
  items    NavItem[]
}

model NavItem {
  id        String         @id @default(cuid())
  menuId    String
  menu      NavigationMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label     String
  url       String
  sortOrder Int            @default(0)
  visible   Boolean        @default(true)
}

model Banner {
  id        String    @id @default(cuid())
  type      String
  icon      String?
  message   String
  detail    String?
  link      String?
  startDate DateTime?
  endDate   DateTime?
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
}

model Promotion {
  id               String    @id @default(cuid())
  name             String
  code             String? // coupon code (null = automatic promo); uniqueness enforced in app
  discountType     String // percentage | fixed | free_shipping | bogo
  value            Decimal   @db.Decimal(10, 2)
  appliesTo        String // all | category | collection | product | tier | min_spend
  targetId         String? // category/collection/product/tier id when scoped
  minSpend         Decimal?  @db.Decimal(10, 2)
  usageLimit       Int?
  perCustomerLimit Int?
  usedCount        Int       @default(0)
  startDate        DateTime?
  endDate          DateTime?
  badgeLabel       String?
  active           Boolean   @default(true)
}

model Redirect {
  id         String  @id @default(cuid())
  fromPath   String  @unique
  toPath     String
  statusCode Int     @default(301)
  active     Boolean @default(true)
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String
  memberTier String?
  rating      Int
  title       String?
  body        String?
  status      String    @default("live") // live | pending | denied
  featured    Boolean   @default(false)
  moderatedBy String?
  moderatedAt DateTime?
  createdAt   DateTime  @default(now())
}

// ----------------------------------------------------------------------------
// Orders (retail)
// ----------------------------------------------------------------------------

model Order {
  id              String      @id @default(cuid())
  ref             String      @unique
  email           String
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String?
  phone           String?
  status          String      @default("received") // received|paid|packed|dispatched|delivered|cancelled
  subtotal        Decimal     @db.Decimal(10, 2)
  shipping        Decimal     @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  currency        String      @default("GBP")
  pointsEarned    Int         @default(0)
  deliveryMethod  String?
  paymentMethod   String?
  paymentStatus   String      @default("simulated") // simulated|paid|pending|refunded
  stripePaymentIntentId String?
  shippingAddress Json?
  internalNotes   String?
  estDeliveryAt   DateTime?
  createdById     String?
  trackingCarrier String?
  trackingNumber  String?
  refundedAmount  Decimal?    @db.Decimal(10, 2)
  refundedAt      DateTime?
  items           OrderItem[]
  timeline        OrderTimeline[]
  returns         Return[]
  placedAt        DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([email])
  @@index([placedAt])
  @@index([customerId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  variantId String?
  name      String
  unitPrice Decimal @db.Decimal(10, 2)
  qty       Int
  lineTotal Decimal @db.Decimal(10, 2)
}

// ----------------------------------------------------------------------------
// Marketing / leads
// ----------------------------------------------------------------------------

model ContactEnquiry {
  id        String   @id @default(cuid())
  type      String   @default("general") // general | trade
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("new") // new | read | replied | closed
  messages  EnquiryMessage[]
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String?
  status    String   @default("subscribed") // subscribed | unsubscribed
  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Loyalty: points ledger, rewards, membership subscriptions
// ----------------------------------------------------------------------------

model PointsLedger {
  id             String   @id @default(cuid())
  customerId     String
  delta          Int
  reason         String // purchase | redemption | referral | review | signup | birthday | adjustment
  relatedOrderId String?
  relatedRewardId String?
  balanceAfter   Int
  note           String?
  createdAt      DateTime @default(now())

  @@index([customerId, createdAt])
}

model Reward {
  id           String  @id @default(cuid())
  name         String
  description  String?
  pointsCost   Int
  type         String  @default("credit") // credit | item | access | discount | experience
  value        String?
  availability String  @default("available") // available | coming_soon | disabled
  sortOrder    Int     @default(0)
}

model MembershipSubscription {
  id                   String    @id @default(cuid())
  customerId           String    @unique
  tierId               String
  billingCycle         String    @default("monthly") // monthly | annual
  price                Decimal   @db.Decimal(10, 2)
  status               String    @default("active") // active | cancelled | past_due
  stripeSubscriptionId String?
  startedAt            DateTime  @default(now())
  nextChargeDate       DateTime?
  cancelledAt          DateTime?
  updatedAt            DateTime  @updatedAt
}

// ----------------------------------------------------------------------------
// Trade / wholesale
// ----------------------------------------------------------------------------

model TradeAccount {
  id               String         @id @default(cuid())
  companyName      String
  contactName      String
  contactEmail     String         @unique
  phone            String?
  businessType     String?
  vatNumber        String?
  authUserId       String?        @unique
  pricingTier      String         @default("Wholesale")
  paymentTerms     String         @default("Net 60")
  creditLimit      Decimal        @default(5000) @db.Decimal(12, 2)
  outstandingBalance Decimal      @default(0) @db.Decimal(12, 2)
  status           String         @default("active") // pending | active | suspended
  accountManager   String?        @default("trade@rumbaclaat.com")
  orders           TradeOrder[]
  invoices         Invoice[]
  messages         TradeMessage[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TradeProductPricing {
  id            String  @id @default(cuid())
  productId     String
  volumeBand    String // 1-4 | 5-9 | 10+
  pricePerBottle Decimal @db.Decimal(10, 2)
  pricePerCase  Decimal @db.Decimal(10, 2)
  sortOrder     Int     @default(0)
}

model TradeOrder {
  id             String       @id @default(cuid())
  ref            String       @unique
  tradeAccountId String
  tradeAccount   TradeAccount @relation(fields: [tradeAccountId], references: [id], onDelete: Cascade)
  lines          Json // [{ productId, name, cases, pricePerBottle }]
  netTotal       Decimal      @db.Decimal(12, 2)
  vat            Decimal      @db.Decimal(12, 2)
  grandTotal     Decimal      @db.Decimal(12, 2)
  poReference    String?
  deliveryNotes  String?
  status         String       @default("processing") // processing | confirmed | delivered | cancelled
  placedAt       DateTime     @default(now())
}

model Invoice {
  id             String       @id @default(cuid())
  ref            String       @unique
  tradeAccountId String
  tradeAccount   TradeAccount @relation(fields: [tradeAccountId], references: [id], onDelete: Cascade)
  tradeOrderId   String?
  amount         Decimal      @db.Decimal(12, 2)
  vat            Decimal      @db.Decimal(12, 2)
  terms          String       @default("Net 60")
  dueDate        DateTime?
  status         String       @default("open") // open | paid | overdue
  issuedAt       DateTime     @default(now())
}

model TradeMessage {
  id             String       @id @default(cuid())
  tradeAccountId String
  tradeAccount   TradeAccount @relation(fields: [tradeAccountId], references: [id], onDelete: Cascade)
  direction      String       @default("inbound") // inbound (from trade) | outbound (from team)
  subject        String?
  body           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// ----------------------------------------------------------------------------
// Collections (curated product sets — M2M with Product)
// ----------------------------------------------------------------------------

model Collection {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  image       String?
  heroImage   String?
  sortOrder   Int                 @default(0)
  active      Boolean             @default(true)
  products    ProductCollection[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ProductCollection {
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)

  @@id([productId, collectionId])
}

// ----------------------------------------------------------------------------
// Tax / shipping classes + zones + currencies (assignable to products/categories)
// ----------------------------------------------------------------------------

model TaxClass {
  id        String  @id @default(cuid())
  name      String
  ratePct   Decimal @default(20) @db.Decimal(5, 2)
  isDefault Boolean @default(false)
  sortOrder Int     @default(0)
}

model ShippingClass {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @default(0) @db.Decimal(10, 2)
  freeOver  Decimal? @db.Decimal(10, 2)
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
}

model ShippingZone {
  id        String   @id @default(cuid())
  name      String
  countries String[]
  price     Decimal  @default(0) @db.Decimal(10, 2)
  freeOver  Decimal? @db.Decimal(10, 2)
  sortOrder Int      @default(0)
}

model Currency {
  code      String  @id // GBP, EUR, USD
  symbol    String
  rate      Decimal @default(1) @db.Decimal(12, 6) // vs base GBP
  isBase    Boolean @default(false)
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

// ----------------------------------------------------------------------------
// Gift cards
// ----------------------------------------------------------------------------

model GiftCard {
  id               String          @id @default(cuid())
  code             String          @unique
  initialAmount    Decimal         @db.Decimal(10, 2)
  balance          Decimal         @db.Decimal(10, 2)
  recipient        String?
  sender           String?
  message          String?
  status           String          @default("active") // active | redeemed | disabled
  purchaserOrderId String?
  txns             GiftCardTxn[]
  createdAt        DateTime        @default(now())
}

model GiftCardTxn {
  id         String   @id @default(cuid())
  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  delta      Decimal  @db.Decimal(10, 2)
  reason     String // issue | redemption | adjustment
  orderId    String?
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Order timeline + returns
// ----------------------------------------------------------------------------

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdBy String? // StaffUser id or "system"
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model Return {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items        Json // [{ name, qty }]
  reason       String?
  status       String   @default("requested") // requested | approved | received | refunded | rejected
  refundAmount Decimal? @db.Decimal(10, 2)
  createdBy    String?
  createdAt    DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Inventory adjustments
// ----------------------------------------------------------------------------

model StockAdjustment {
  id        String   @id @default(cuid())
  productId String?
  variantId String?
  delta     Int
  reason    String // restock | correction | damage | sale | return
  note      String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([productId, createdAt])
}

// ----------------------------------------------------------------------------
// Audit log (every back-office mutation)
// ----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  staffId    String?
  staffEmail String
  action     String // "product.update"
  entityType String
  entityId   String?
  summary    String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// Enquiry message thread
// ----------------------------------------------------------------------------

model EnquiryMessage {
  id        String         @id @default(cuid())
  enquiryId String
  enquiry   ContactEnquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  direction String         @default("outbound") // inbound (from customer) | outbound (from team)
  body      String
  staffEmail String?
  emailSent Boolean        @default(false)
  createdAt DateTime       @default(now())
}

// ----------------------------------------------------------------------------
// Storefront: server cart, wishlist, back-in-stock
// ----------------------------------------------------------------------------

model Cart {
  id         String   @id @default(cuid())
  token      String   @unique
  customerId String?
  email      String?
  items      Json     @default("[]") // [{ productId, variantId?, qty }]
  recovered  Boolean  @default(false)
  reminderSentAt DateTime?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
}

model StockNotification {
  id        String   @id @default(cuid())
  email     String
  productId String
  variantId String?
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
}
