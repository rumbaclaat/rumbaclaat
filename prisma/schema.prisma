// Rumbaclaat — Prisma schema (Prisma 7, new `prisma-client` generator).
// Starter core models; expanded to the full §4 model before the first migration.
// Run `npm run db:push` (or db:migrate) once Supabase DATABASE_URL/DIRECT_URL are set.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Catalogue
// ----------------------------------------------------------------------------

enum ProductType {
  rum
  apparel
  cap
  gift_card
}

enum PublishStatus {
  draft
  published
  archived
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  heroImage   String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  sku         String        @unique
  type        ProductType
  name        String
  subtitle    String?
  description String?
  categoryId  String?
  category    Category?     @relation(fields: [categoryId], references: [id])
  basePrice   Decimal       @db.Decimal(10, 2)
  onSale      Boolean       @default(false)
  salePrice   Decimal?      @db.Decimal(10, 2)
  saleEndDate DateTime?
  basePoints  Int           @default(0)
  // Rum-specific
  abv         Decimal?      @db.Decimal(5, 2)
  volume      String?
  origin      String?
  // Apparel-specific
  material    String?
  // Display
  ratingAvg   Decimal?      @db.Decimal(3, 2)
  reviewCount Int           @default(0)
  stockQty    Int           @default(0)
  maxQtyPerOrder Int?
  status      PublishStatus @default(draft)
  variants    ProductVariant[]
  reviews     Review[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colourName  String?
  colourHex   String?
  size        String?
  sku         String   @unique
  priceDelta  Decimal  @default(0) @db.Decimal(10, 2)
  stockQty    Int      @default(0)
  createdAt   DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Customers & membership
// ----------------------------------------------------------------------------

model MembershipTier {
  id              String     @id @default(cuid())
  name            String     @unique // Bronze | Silver | Gold | Black Reserve
  slug            String     @unique
  priceMonthly    Decimal    @default(0) @db.Decimal(10, 2)
  priceAnnual     Decimal    @default(0) @db.Decimal(10, 2)
  pointsMultiplier Decimal   @default(1) @db.Decimal(4, 2)
  memberDiscountPct Int      @default(0)
  isFree          Boolean    @default(false)
  benefits        String[]
  sortOrder       Int        @default(0)
  customers       Customer[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Customer {
  id              String          @id @default(cuid())
  authUserId      String?         @unique // Supabase auth.users id
  firstName       String?
  lastName        String?
  email           String          @unique
  phone           String?
  dateOfBirth     DateTime?
  membershipTierId String?
  membershipTier  MembershipTier? @relation(fields: [membershipTierId], references: [id])
  pointsBalance   Int             @default(0)
  lifetimeSpend   Decimal         @default(0) @db.Decimal(12, 2)
  referralCode    String?         @unique
  ghlContactId    String?
  addresses       Address[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String?
  line1      String
  line2      String?
  city       String
  postcode   String
  country    String   @default("United Kingdom")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Site settings (singleton)
// ----------------------------------------------------------------------------

model Settings {
  id                   String  @id @default("default")
  shippingStandardCost Decimal @default(4.99) @db.Decimal(10, 2)
  shippingExpressCost  Decimal @default(9.99) @db.Decimal(10, 2)
  freeShippingThreshold Decimal @default(50) @db.Decimal(10, 2)
  pointsPerPound       Int     @default(100) // 100 points = £1 on redemption
  vatRatePct           Int     @default(20)
  currency             String  @default("GBP")
  ageThreshold         Int     @default(18)
  ghlConfig            Json?
  updatedAt            DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Back-office staff (RBAC) — linked to Supabase auth.users
// ----------------------------------------------------------------------------

enum StaffRole {
  super_admin
  content_editor
  catalogue_manager
  order_manager
  membership_manager
  trade_manager
  marketing_manager
}

model StaffUser {
  id         String    @id @default(cuid())
  authUserId String    @unique
  email      String    @unique
  name       String?
  role       StaffRole @default(content_editor)
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ----------------------------------------------------------------------------
// Media library (Supabase Storage)
// ----------------------------------------------------------------------------

model Media {
  id         String   @id @default(cuid())
  bucketPath String   @unique
  url        String
  alt        String?
  width      Int?
  height     Int?
  mimeType   String?
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------------
// CMS pages + reorderable content blocks
// ----------------------------------------------------------------------------

enum BlockType {
  hero_carousel
  hero_banner
  announcement_ticker
  trust_bar
  parallax_callout
  featured_products
  sale_strip
  membership_tiers
  membership_promo
  gift_card
  cocktails_grid
  blog_grid
  featured_article
  rich_text
  two_col
  stat_block
  card_grid
  newsletter
  social_grid
  faq_accordion
  cta_band
  reviews
}

model Page {
  id             String         @id @default(cuid())
  slug           String         @unique
  templateType   String         @default("content")
  title          String
  status         PublishStatus  @default(draft)
  seoTitle       String?
  seoDescription String?
  canonical      String?
  robots         String?        @default("index,follow")
  ogImage        String?
  blocks         ContentBlock[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ContentBlock {
  id        String    @id @default(cuid())
  pageId    String
  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      BlockType
  order     Int       @default(0)
  visible   Boolean   @default(true)
  data      Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([pageId, order])
}

// ----------------------------------------------------------------------------
// Editorial: blog + cocktails + FAQ
// ----------------------------------------------------------------------------

model Author {
  id     String     @id @default(cuid())
  name   String
  title  String?
  bio    String?
  avatar String?
  posts  BlogPost[]
}

model BlogPost {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  category       String?
  excerpt        String?
  body           String?
  heroImage      String?
  authorId       String?
  author         Author?       @relation(fields: [authorId], references: [id])
  readTime       String?
  featured       Boolean       @default(false)
  status         PublishStatus @default(draft)
  publishDate    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Cocktail {
  id                String        @id @default(cuid())
  slug              String        @unique
  name              String
  eyebrow           String?
  lede              String?
  difficulty        String?
  occasion          String?
  timeMins          Int?
  ingredients       Json?
  method            Json?
  serviceNotes      Json?
  bartenderTip      String?
  image             String?
  featuredProductId String?
  status            PublishStatus @default(draft)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model FAQItem {
  id        String  @id @default(cuid())
  category  String?
  question  String
  answer    String
  sortOrder Int     @default(0)
}

// ----------------------------------------------------------------------------
// Navigation, banners, promotions, redirects, reviews
// ----------------------------------------------------------------------------

model NavigationMenu {
  id       String    @id @default(cuid())
  location String    @unique
  items    NavItem[]
}

model NavItem {
  id        String         @id @default(cuid())
  menuId    String
  menu      NavigationMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label     String
  url       String
  sortOrder Int            @default(0)
  visible   Boolean        @default(true)
}

model Banner {
  id        String    @id @default(cuid())
  type      String
  icon      String?
  message   String
  detail    String?
  link      String?
  startDate DateTime?
  endDate   DateTime?
  active    Boolean   @default(true)
  sortOrder Int       @default(0)
}

model Promotion {
  id           String    @id @default(cuid())
  name         String
  discountType String
  value        Decimal   @db.Decimal(10, 2)
  appliesTo    String
  startDate    DateTime?
  endDate      DateTime?
  badgeLabel   String?
  active       Boolean   @default(true)
}

model Redirect {
  id         String  @id @default(cuid())
  fromPath   String  @unique
  toPath     String
  statusCode Int     @default(301)
  active     Boolean @default(true)
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String
  memberTier String?
  rating     Int
  title      String?
  body       String?
  status     String   @default("live")
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Orders (retail)
// ----------------------------------------------------------------------------

model Order {
  id              String      @id @default(cuid())
  ref             String      @unique
  email           String
  customerName    String?
  phone           String?
  status          String      @default("received") // received|paid|packed|dispatched|delivered|cancelled
  subtotal        Decimal     @db.Decimal(10, 2)
  shipping        Decimal     @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  pointsEarned    Int         @default(0)
  deliveryMethod  String?
  paymentMethod   String?
  paymentStatus   String      @default("simulated") // simulated|paid|pending|refunded
  shippingAddress Json?
  items           OrderItem[]
  placedAt        DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([email])
  @@index([placedAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  variantId String?
  name      String
  unitPrice Decimal @db.Decimal(10, 2)
  qty       Int
  lineTotal Decimal @db.Decimal(10, 2)
}
