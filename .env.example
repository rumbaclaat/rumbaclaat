# ----------------------------------------------------------------------------
# Rumbaclaat — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase project.
# (.env.local is gitignored and never committed.)
# ----------------------------------------------------------------------------

# Supabase project URL + keys
#   Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection strings
#   Dashboard → Project Settings → Database → Connection string
#   DATABASE_URL = pooled connection (port 6543, ?pgbouncer=true) used by the app
#   DIRECT_URL   = direct connection (port 5432) used by Prisma migrations
DATABASE_URL=
DIRECT_URL=

# ---- Added in later phases (leave blank for now) ----
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# GoHighLevel (LeadConnector API v2)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=
